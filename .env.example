# HACK-26 — local config
# Tudo abaixo é opcional. Sem nenhuma chave, o app roda com SQLite local
# e juízes determinísticos (mock). Adicione chaves pra acionar a stack real.

# senha compartilhada do júri (login em /judge/login)
# default em dev: "hack26"
JUDGE_PASSWORD=

# AI Gateway da Vercel (preferido) — habilita os juízes-IA reais
AI_GATEWAY_API_KEY=

# alternativa: chave direta do Anthropic (o AI SDK pega automaticamente)
ANTHROPIC_API_KEY=

# token do GitHub (read-only) — sobe o rate limit do fetcher de repos
# de 60 req/h pra 5000 req/h. Útil em demo se você roda várias avaliações.
GITHUB_TOKEN=
